[Unit]
Description=Generate rEFInd btrfs snapshot boot entries
Documentation=https://github.com/jmylchreest/refind-btrfs-snapshots
After=local-fs.target
Before=snapper-boot.service
ConditionPathExists=/usr/bin/refind-btrfs-snapshots
ConditionPathExists=/etc/refind-btrfs-snapshots.yaml

[Service]
Type=oneshot
# Settle window: a kernel rebuild or snapshot rotation produces a burst of
# writes. Sleep briefly so they coalesce; because this is Type=oneshot, triggers
# arriving during the sleep/run collapse into at most one re-run.
ExecStartPre=/usr/bin/sleep 5
ExecStart=/usr/bin/refind-btrfs-snapshots --config /etc/refind-btrfs-snapshots.yaml generate -g -y
User=root
StandardOutput=journal
StandardError=journal
TimeoutStartSec=300
SyslogIdentifier=refind-btrfs-snapshots

[Install]
WantedBy=multi-user.target
